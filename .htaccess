DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteRule ^(\.env|\.git|config\.php|HOSTINGER_DEPLOY\.md|README\.md)$ - [F,L]
    RewriteRule ^(app|database|scripts|storage)(/|$) - [F,L]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.php [L]
</IfModule>

<FilesMatch "^(\.env|\.gitignore|config\.php|.*\.md)$">
    Require all denied
</FilesMatch>
